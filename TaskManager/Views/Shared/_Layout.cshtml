<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - TaskManager</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/TaskManager.styles.css" asp-append-version="true" />
</head>

<body class="d-flex flex-column min-vh-100">
    <header>
        <nav class="navbar navbar-expand-lg navbardark bg-dark">
            <div class="container-fluid">
                <a class="navbar-brand text-uppercase fw-bold" asp-controller="Home" asp-action="Index">
                    <i class="bi bi-house-door"></i> Inicio
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
                    aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <div class="d-flex w-100 justify-content-around">
                        @if (Context.Session.GetInt32("idSesion") != null)
                        {
                            @if (Context.Session.GetString("rolSesion") == "Administrador")
                            {
                                <a class="nav-link text-light" asp-controller="Usuarios" asp-action="Index">
                                    <i class="bi bi-people"></i> Usuarios
                                </a>
                            }
                            <a class="nav-link text-light" asp-controller="Tablero" asp-action="Index">
                                <i class="bi bi-kanban"></i> Mis Tableros
                            </a>
                            <a class="nav-link text-light" asp-controller="Tablero" asp-action="TablerosAsignados">
                                <i class="bi bi-list-task"></i> Asignados
                            </a>
                            <a class="nav-link text-light" asp-controller="Usuarios" asp-action="Password"
                                asp-route-idUsuario="@Context.Session.GetInt32("idSesion")">
                                <i class="bi bi-key"></i> Contraseña
                            </a>
                            <a class="nav-link text-danger" asp-controller="Login" asp-action="Logout">
                                <i class="bi bi-box-arrow-left"></i> Salir
                            </a>
                        }
                    </div>
                </div>
            </div>
        </nav>
    </header>
    
    <main role="main" class="container flex-grow-1 d-flex align-items-center justify-content-center">
        @RenderBody()
    </main>

    <footer class="bg-dark text-light text-center py-3 mt-auto">
        &copy; 2026 - TaskManager - 
        <a href="https://github.com/PabloCampanini/proyecto-final-is" target="_blank"
            class="btn btn-dark">
            <i class="bi bi-github"></i> About this proyect
        </a>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>

</html>