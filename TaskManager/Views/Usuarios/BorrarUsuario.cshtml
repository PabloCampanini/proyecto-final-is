@{
    ViewData["title"] = "Borrar usuario";
}

@model Usuarios

<section class="container text-center mt-5">
    <h2 class="text-danger">⚠ Atención ⚠</h2>
    <p class="lead">Está a punto de eliminar al usuario <strong>@Model.NombreDeUsuario</strong> con email <strong>@Model.Email</strong>.</p>
    <p class="fw-bold">Esta acción es irreversible. ¿Desea continuar?</p>

    <!-- Botón para abrir el modal -->
    <button type="button" class="btn btn-danger btn-lg px-4" data-bs-toggle="modal" data-bs-target="#confirmarEliminacion">
        Eliminar Usuario
    </button>

    <a asp-controller="Usuarios" asp-action="Index" class="btn btn-secondary btn-lg px-4">Cancelar</a>
</section>

<!-- Modal de Confirmación -->
<section class="modal fade" id="confirmarEliminacion" tabindex="-1" aria-labelledby="confirmarEliminacionLabel" aria-hidden="true">
    <section class="modal-dialog modal-dialog-centered">
        <section class="modal-content">
            <header class="modal-header bg-danger text-white">
                <h5 class="modal-title" id="confirmarEliminacionLabel">Confirmación de Eliminación</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </header>
            <main class="modal-body text-center">
                <p>¿Está seguro de que desea eliminar al usuario <strong>@Model.NombreDeUsuario</strong>?</p>
                <p class="text-muted">Esta acción no se puede deshacer.</p>
            </main>
            <footer class="modal-footer">
                <form asp-controller="Usuarios" asp-action="BorrarUsuario" method="post">
                    <input type="hidden" asp-for="IdUsuario">
                    <button type="submit" class="btn btn-danger">Sí, eliminar</button>
                </form>
                <a asp-controller="Usuarios" asp-action="Index" class="btn btn-secondary">Cancelar</a>
            </footer>
        </section>
    </section>
</section>