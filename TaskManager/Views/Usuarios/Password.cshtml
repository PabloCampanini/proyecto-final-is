@{
    ViewData["Title"] = "Modificar Contraseña";
}

@model ModificarContraseñaVM

<section class="container mt-4 py-3">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <h2 class="text-center mb-4">Modificar Contraseña</h2>

            <form asp-controller="Usuarios" asp-action="Password" method="post">

                <input type="hidden" asp-for="IdUsuarioB" />

                <div class="mb-3">
                    <label asp-for="newPassword" class="form-label"></label>
                    <input asp-for="newPassword" type="password" class="form-control" />
                </div>

                <div class="mb-3">
                    <label class="form-label">Confirmar Contraseña</label>
                    <input type="password" class="form-control" />
                </div>

                <button type="submit" class="btn btn-primary w-100 mb-2">
                    Guardar Cambios
                </button>

                <a asp-controller="Home" asp-action="Index" class="btn btn-secondary w-100">
                    Cancelar
                </a>

            </form>
        </div>
    </div>
</section>