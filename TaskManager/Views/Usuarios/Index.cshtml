@{
    ViewData["Title"] = "Lista de Usuarios";
}

@model ListarUsuariosVM

<section><!-- Buscador -->
    <section class="buscador-container mt-4">
        <section class="row justify-content-center">
            <section class="col-md-6">
                <i class="bi bi-search"></i>
                <input type="text" id="buscador" class="buscador" placeholder="Buscar por ID, Nombre, Email o Rol...">
            </section>
        </section>
    </section>

    <!-- Botón de Crear Nuevo Usuario -->
    <section class="text-center mt-4">
        <a class="btn btn-success btn-md" role="button" asp-controller="Usuarios" asp-action="CrearUsuario">
            <i class="bi bi-person-plus"></i> Cargar Nuevo Usuario
        </a>
    </section>

    <section class="text-center contariner mt-4">
        <!-- Tabla de Administradores -->
        <section class="table-responsive">
            <table id="tablaAdministradores"
                class="table table-striped table-hover table-bordered text-center align-middle">
                <caption class="text-center text-primary">Administradores</caption>
                <thead class="table-primary">
                    <tr>
                        <th scope="col">ID</th>
                        <th scope="col">Nombre</th>
                        <th scope="col">Email</th>
                        <th scope="col">Rol</th>
                        <th colspan="2">Acciones</th>
                        <th scope="col">Tableros</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var usuario in Model.Administradores)
                    {
                        if (Context.Session.GetInt32("idSesion") != usuario.IdUsuario)
                        {
                            <tr>
                                <th scope="row">@usuario.IdUsuario</th>
                                <td>@usuario.NombreDeUsuario</td>
                                <td>@usuario.Email</td>
                                <td>Administrador</td>
                                <td>
                                    <a class="btn btn-sm btn-warning" role="button" asp-area="" asp-controller="Usuarios"
                                        asp-action="ModificarUsuario" asp-route-idUsuarioB="@usuario.IdUsuario"><i
                                            class="bi bi-pencil"></i> Modificar</a>
                                </td>
                                <td>
                                    <a class="btn btn-sm btn-danger" role="button" asp-area="" asp-controller="Usuarios"
                                        asp-action="BorrarUsuario" asp-route-idUsuarioB="@usuario.IdUsuario">
                                        <i class="bi bi-trash"></i> Eliminar</a>
                                </td>
                                <td>
                                    <a class="btn btn-sm btn-primary" role="button" asp-area="" asp-controller="Tablero"
                                        asp-action="TablerosOtroUsuario" asp-route-idUsuarioB="@usuario.IdUsuario">
                                        <i class="bi bi-eye"></i> Ver Tableros</a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </section>
    </section>


    <section class="text-center contariner mt-4">
        <!-- Tabla de Operadores -->
        <section class="table-responsive">
            <table id="tablaOperadores" class="table table-striped table-hover table-bordered text-center align-middle">
                <caption class="text-center text-success">Operadores</caption>
                <thead class="table-success">
                    <tr>
                        <th scope="col">ID</th>
                        <th scope="col">Nombre</th>
                        <th scope="col">Email</th>
                        <th scope="col">Rol</th>
                        <th colspan="2">Acciones</th>
                        <th scope="col">Tableros</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var usuario in Model.Operadores)
                    {
                        <tr>
                            <th scope="row">@usuario.IdUsuario</th>
                            <td>@usuario.NombreDeUsuario</td>
                            <td>@usuario.Email</td>
                            <td>Operador</td>
                            <td>
                                <a class="btn btn-sm btn-warning" role="button" asp-area="" asp-controller="Usuarios"
                                    asp-action="ModificarUsuario" asp-route-idUsuarioB="@usuario.IdUsuario"><i
                                        class="bi bi-pencil"></i> Modificar</a>
                            </td>
                            <td>
                                <a class="btn btn-sm btn-danger" role="button" asp-area="" asp-controller="Usuarios"
                                    asp-action="BorrarUsuario" asp-route-idUsuarioB="@usuario.IdUsuario">
                                    <i class="bi bi-trash"></i> Eliminar</a>
                            </td>
                            <td>
                                <a class="btn btn-sm btn-primary" role="button" asp-area="" asp-controller="Tablero"
                                    asp-action="TablerosOtroUsuario" asp-route-idUsuarioB="@usuario.IdUsuario">
                                    <i class="bi bi-eye"></i> Ver Tableros</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </section>
    </section>

    <section class="text-center contariner mt-4">
        <!-- Tabla de Resultados Filtrados -->
        <section class="table-responsive">
            <table id="tablaUnificada" class="table table-striped table-hover table-bordered text-center align-middle"
                style="display: none;">
                <caption class="text-center text-warning">Resultados de Búsqueda</caption>
                <thead class="table-warning">
                    <tr>
                        <th scope="col">ID</th>
                        <th scope="col">Nombre</th>
                        <th scope="col">Email</th>
                        <th scope="col">Rol</th>
                        <th colspan="2">Acciones</th>
                        <th scope="col">Tableros</th>
                    </tr>
                </thead>
                <tbody id="tablaUnificadaBody">
                    @foreach (var usuario in Model.Administradores.Concat(Model.Operadores))
                    {
                        <tr>
                            <th scope="row">@usuario.IdUsuario</th>
                            <td>@usuario.NombreDeUsuario</td>
                            <td>@usuario.Email</td>
                            <td>@(usuario.Rol == RolUsuario.Administrador ? "Administrador" : "Operador")</td>
                            <td>
                                <a class="btn btn-sm btn-primary" role="button" asp-area="" asp-controller="Usuarios"
                                    asp-action="ModificarUsuario" asp-route-idUsuarioB="@usuario.IdUsuario">Modificar</a>
                            </td>
                            <td>
                                <a class="btn btn-sm btn-danger" role="button" asp-area="" asp-controller="Usuarios"
                                    asp-action="BorrarUsuario" asp-route-idUsuarioB="@usuario.IdUsuario">Eliminar</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </section>
    </section>
</section>

<script src="~/js/ListaUsuarios.js"></script>