@{
    ViewData["title"] = "Lista tareas";
}

@model ListarTareaVM

<section class="container mt-5">
    <h2 class="text-center mb-4">@Model.NombreTablero</h2>
    <h3 class="text-center mb-4">@Model.DescripcionTablero</h3>
    
        <nav class="d-flex justify-content-between align-items-center my-3">
            <!-- Botones a la izquierda -->
            <section>
                @if (Context.Session.GetInt32("idSesion") == Model.IdCreadorTablero)
                {
                    <a asp-controller="Tablero" asp-action="ModificarTablero" asp-route-idTableroB="@Model.IdTablero"
                        class="btn btn-warning btn-sm"><i class="bi bi-pencil"></i> Modificar Tabla</a>
                }    
               
                @if (Context.Session.GetString("rolSesion") == "Administrador")
                {
                    <a asp-controller="Tablero" asp-action="CambiarPropietario" asp-route-idTableroB="@Model.IdTablero"
                        class="btn btn-primary btn-sm">
                        <i class="bi bi-person"></i> Cambiar Propietario
                    </a>
                }

                @if ((Context.Session.GetInt32("idSesion") == Model.IdCreadorTablero) || (Context.Session.GetString("rolSesion") == "Administrador"))
                {
                    <a asp-controller="Tablero" asp-action="BorrarTablero" asp-route-idTableroB="@Model.IdTablero"
                        class="btn btn-danger btn-sm"><i class="bi bi-trash"></i> Eliminar Tabla
                    </a>
                }    
            </section>

            <!-- Botones a la derecha -->
            <section>
                @if (Context.Session.GetInt32("idSesion") == Model.IdCreadorTablero)
                {
                    <a asp-controller="Tareas" asp-action="CrearTarea" asp-route-idTableroB="@Model.IdTablero"
                        class="btn btn-success btn-sm"><i class="bi bi-plus"></i> Agregar Tarea</a>
                }
            </section>
        </nav>



    <section class="table-responsive">
        <table class="table table-bordered text-center align-middle w-90">
            <thead class="table-dark align-middle">
                <tr>
                    @if (Context.Session.GetInt32("idSesion") == Model.IdCreadorTablero)
                    {
                        <th class="w-20">Ideas</th>
                    }
                    <th class="w-20">Por Hacer</th>
                    <th class="w-20">En Proceso</th>
                    <th class="w-20">En Revisión</th>
                    <th class="w-20">Completadas</th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    @if (Context.Session.GetInt32("idSesion") == Model.IdCreadorTablero)
                    {
                        <!-- IDEAS -->
                        <td class="w-20">
                            @foreach (var tarea in Model.TareasIdeas)
                            {
                                <div class="d-flex flex-column p-2 mb-2 border rounded shadow-sm"
                                    style="background-color: #f8f9fa; width: 100%;">
                                    <div class="d-flex align-items-center">
                                        <span class="flex-shrink-0 me-2 d-inline-block rounded-circle"
                                            style="width: 12px; height: 12px; background-color: #6c757d;"></span>
                                        <p class="fw-bold">#@tarea.IdTarea @tarea.Nombre</p>
                                    </div>
                                    <div>
                                        <hr>
                                        <small class="fw-bold">@tarea.Descripcion</small>
                                    </div>
                                    <div class="d-flex justify-content-evenly mt-2">
                                        <a asp-controller="Tareas" asp-action="BorrarTarea" asp-route-idTareaB="@tarea.IdTarea"
                                            class="rounded-circle btn btn-danger btn-sm opacity-75">
                                            <i class="bi bi-trash"></i>
                                        </a>
                                        <a asp-controller="Tareas" asp-action="ModificarTarea"
                                            asp-route-idTareaB="@tarea.IdTarea"
                                            class="rounded-circle btn btn-warning btn-sm opacity-75">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <a asp-controller="Tareas" asp-action="MoverTareaDerecha"
                                            asp-route-idTarea="@tarea.IdTarea"
                                            class="rounded-circle btn btn-success btn-sm opacity-75">
                                            <i class="bi bi-arrow-right"></i>
                                        </a>
                                    </div>
                                </div>
                            }
                        </td>
                    }

                    <!-- PRIORIDAD (ALTA Y MEDIA) -->
                    <td class="w-20">
                        @foreach (var tarea in Model.TareasPorHacer)
                        {
                            @if (tarea.Color == Color.Red)
                            {
                                @if((Context.Session.GetInt32("idSesion") == Model.IdCreadorTablero) || 
                                    (Context.Session.GetString("rolSesion") == "Administrador") || 
                                    (Context.Session.GetInt32("idSesion") == tarea.IdUsuarioAsignado))
                                {
                                    <div class="d-flex flex-column p-2 mb-2 border rounded shadow-sm"
                                        style="background-color: #f8d7da; width: 100%;">
                                        <div class="d-flex align-items-center">
                                            <span class="flex-shrink-0 me-2 d-inline-block rounded-circle"
                                                style="width: 12px; height: 12px; background-color: #dc3545;"></span>
