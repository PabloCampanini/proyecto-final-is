@{
    ViewData["title"] = "Tableros";
}

@model ListarTablerosVM

<section class="container mt-5 py-3">
    <h2 class="text-center mb-4">Tableros</h2>

    <!-- Tableros del Usuario -->
    <article>
        <h3 class="text-start mb-3">Tableros del Usuario</h3>
        <section class="row row-cols-1 row-cols-md-3 g-4">
            @foreach (var tablero in Model.TablerosUsuario.Where(t => t.IdUsuarioPropietario == Model.Propietario))
            {
                <section class="col">
                    <a asp-controller="Tareas" asp-action="Index" asp-route-idTablero="@tablero.IdTablero"
                        class="d-block text-decoration-none position-relative overflow-hidden rounded-4 shadow-lg">
                        <img src="~/img/Metodo-Kanban.jpg" class="w-100 rounded-top-4" alt="Tablero">
                        <p class="bg-black text-white text-center py-3 rounded-bottom-4 fw-bold m-0">
                            @tablero.Nombre
                        </p>
                    </a>

                    <!-- Botones de acciones -->
                    <section class="d-flex justify-content-between mt-2">
                        <a asp-controller="Tablero" asp-action="BorrarTablero" asp-route-idTableroB="@tablero.IdTablero"
                            class="btn btn-danger btn-sm">
                            <i class="bi bi-trash"></i> Eliminar
                        </a>

                        <a asp-controller="Tablero" asp-action="CambiarPropietario"
                            asp-route-idTableroB="@tablero.IdTablero" class="btn btn-warning btn-sm">
                            <i class="bi bi-person"></i> Cambiar Propietario
                        </a>
                    </section>
                </section>
            }
        </section>
    </article>

    <!-- Tableros Asignados -->
    <article class="mt-5">
        <h3 class="text-start mb-3">Tableros Asignados</h3>
        <section class="row row-cols-1 row-cols-md-3 g-4">
            @foreach (var tablero in Model.TablerosUsuario.Where(t => t.IdUsuarioPropietario != Model.Propietario))
            {
                <section class="col">
                    <a asp-controller="Tareas" asp-action="Index" asp-route-idTablero="@tablero.IdTablero"
                        class="d-block text-decoration-none position-relative overflow-hidden rounded-4 shadow-lg">
                        <img src="~/img/Metodo-Kanban.jpg" class="w-100 rounded-top-4" alt="Tablero">
                        <p class="bg-black text-white text-center py-3 rounded-bottom-4 fw-bold m-0">
                            @tablero.Nombre
                        </p>
                    </a>
                </section>
            }
        </section>
    </article>
</section>